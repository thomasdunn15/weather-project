DATABASE_URL=postgresql://username:password@localhost:5432/weather
LOG_LEVEL=INFO

# Dashboard (FastAPI) — optional; only read by `python -m dashboard.app`.
# When launching via the uvicorn CLI, pass --host/--port instead.
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8000

# Kalshi live-trading credentials (optional; needed for the live dashboard tab
# and the trading crons). The private key path is read by weather_markets.config.
# KALSHI_KEY_ID=
# KALSHI_KEY_PATH=~/.kalshi/key.pem
# KALSHI_API_BASE=https://api.elections.kalshi.com